# ArtShift Backend 环境变量
# 复制此文件为 .env，填入真实值后使用

# Server
PORT=8080
NODE_ENV=development

# Supabase Database
# 获取方式：Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.oheyqzqnkhpmmkrxavni.supabase.co:5432/postgres

# Supabase Project
# 获取方式：Settings → API → Project API keys
SUPABASE_URL=https://oheyqzqnkhpmmkrxavni.supabase.co
SUPABASE_ANON_KEY=[粘贴你的 anon public key]
SUPABASE_SERVICE_ROLE_KEY=[粘贴你的 service_role key]

# Stability AI（获取 $10 免费额度：https://platform.stability.ai）
STABILITY_API_KEY=[粘贴你的 Stability AI API Key]

# CORS 白名单
FRONTEND_URL=https://artshift.api-tokenmaster.com